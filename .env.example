# ===================================
# Global Environment Variables
# ===================================
NODE_ENV=development
LOG_LEVEL=debug

# ===================================
# Frontend (Next.js) Configuration
# ===================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org:443
NEXT_PUBLIC_SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_APP_NAME=StellarVault
NEXT_PUBLIC_APP_VERSION=0.1.0

# Frontend Auth
NEXT_PUBLIC_AUTH_SECRET=your_auth_secret_here
AUTH_SECRET=your_auth_secret_here

# Wallet Configuration
NEXT_PUBLIC_FREIGHTER_ENABLED=true
NEXT_PUBLIC_LEDGER_ENABLED=true
NEXT_PUBLIC_TREZOR_ENABLED=true

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_SENTRY_DSN=

# ===================================
# Backend (NestJS) Configuration
# ===================================
API_PORT=3001
API_HOST=localhost
API_CORS_ORIGIN=http://localhost:3000

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=stellar_vault
DATABASE_SSL=false

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Stellar Network Configuration
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban Smart Contracts
CONTRACT_VAULT_ID=your_vault_contract_id
CONTRACT_TOKEN_ID=your_token_contract_id
CONTRACT_PAYMENT_ID=your_payment_contract_id

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@stellarvault.com

# AWS S3 Configuration (if applicable)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=stellar-vault-uploads

# Stripe Integration (for payments)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT=3600000

# ===================================
# Soroban Smart Contracts
# ===================================
SOROBAN_NETWORK=testnet
SOROBAN_ACCOUNT_SECRET=your_soroban_account_secret_here

# ===================================
# Docker Configuration
# ===================================
DOCKER_REGISTRY=docker.io
DOCKER_NAMESPACE=novacorelabs

# ===================================
# GitHub Actions / CI/CD
# ===================================
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=NovaCoreLabs1
GITHUB_REPO_NAME=StellarVault

# ===================================
# Development Tools
# ===================================
DEBUG=stellar-vault:*
VERBOSE=false
